<?xml version="1.0"?>
<sdf version="1.6">
  <model name="ego_hatchback">
    <pose>0 0 0 0 0 0</pose>

    <!-- ============== CHASSIS ============== -->
    <link name="chassis">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>1200</mass>
        <pose>0 0 0.4 0 0 0</pose>
        <inertia>
          <ixx>500</ixx><iyy>1500</iyy><izz>1800</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="chassis_collision">
        <pose>0 0 0.9 0 0 0</pose>
        <geometry>
          <box><size>4.2 1.8 1.2</size></box>
        </geometry>
      </collision>
      <visual name="chassis_visual">
        <pose>0 0 0 0 0 1.57079632679</pose>
        <geometry>
          <mesh>
            <scale>0.0254 0.0254 0.0254</scale>
            <uri>model://hatchback/meshes/hatchback.obj</uri>
          </mesh>
        </geometry>
      </visual>
    </link>

    <!-- ============== WHEELS (link는 안 눕힘, visual만 회전) ============== -->
    <!-- Front wheels: low mu2 (lateral) so the car can rotate in place.
         Passive (non-driven) wheels act like casters for diff-drive. -->
    <link name="wheel_fl">
      <pose>1.3 0.85 0.3 0 0 0</pose>
      <inertial>
        <mass>15</mass>
        <inertia><ixx>0.5</ixx><iyy>0.5</iyy><izz>0.5</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="wheel_fr">
      <pose>1.3 -0.85 0.3 0 0 0</pose>
      <inertial>
        <mass>15</mass>
        <inertia><ixx>0.5</ixx><iyy>0.5</iyy><izz>0.5</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="wheel_rl">
      <pose>-1.3 0.85 0.3 0 0 0</pose>
      <inertial>
        <mass>15</mass>
        <inertia><ixx>0.5</ixx><iyy>0.5</iyy><izz>0.5</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <link name="wheel_rr">
      <pose>-1.3 -0.85 0.3 0 0 0</pose>
      <inertial>
        <mass>15</mass>
        <inertia><ixx>0.5</ixx><iyy>0.5</iyy><izz>0.5</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <collision name="c">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction></surface>
      </collision>
      <visual name="v">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.3</radius><length>0.2</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
    </link>

    <!-- ============== JOINTS (axis: Y = 좌우 방향) ============== -->
    <joint name="wheel_fl_joint" type="revolute">
      <parent>chassis</parent><child>wheel_fl</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="wheel_fr_joint" type="revolute">
      <parent>chassis</parent><child>wheel_fr</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="wheel_rl_joint" type="revolute">
      <parent>chassis</parent><child>wheel_rl</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping></dynamics>
      </axis>
    </joint>
    <joint name="wheel_rr_joint" type="revolute">
      <parent>chassis</parent><child>wheel_rr</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><damping>0.01</damping></dynamics>
      </axis>
    </joint>

    <!-- ============== LiDAR ============== -->
    <link name="lidar_link">
      <pose>0 0 1.5 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="v">
        <geometry><cylinder><radius>0.05</radius><length>0.1</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
      <sensor name="lidar" type="ray">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <ray>
          <scan><horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal></scan>
          <range>
            <min>0.3</min>
            <max>12.0</max>
            <resolution>0.02</resolution>
          </range>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
        </ray>
        <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>/ego</namespace>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>lidar_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>chassis</parent><child>lidar_link</child>
    </joint>

    <!-- ============== FRONT CAMERA ============== -->
    <!-- Mounted at front of chassis, 1m height, tilted 20° down to capture ground markers -->
    <link name="camera_link">
      <pose>2.0 0 1.0 0 0.35 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.1 0.05</size></box></geometry>
        <material><ambient>0.1 0.1 0.9 1</ambient><diffuse>0.1 0.1 0.9 1</diffuse></material>
      </visual>
      <sensor name="camera" type="camera">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <camera>
          <horizontal_fov>1.3962634</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>30.0</far></clip>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
        </camera>
        <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/ego</namespace>
            <remapping>image_raw:=camera/image_raw</remapping>
            <remapping>camera_info:=camera/camera_info</remapping>
          </ros>
          <frame_name>camera_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>chassis</parent><child>camera_link</child>
    </joint>

    <!-- ============== LEFT SIDE CAMERA (Row A / 북쪽 슬롯) ============== -->
    <!-- Mounted on the left flank (chassis +y = north when driving east).
         yaw=+π/2  → optical axis faces chassis +y (left).
         pitch=0.15 → ~9° downward tilt to capture slot markers on the ground. -->
    <link name="camera_left_link">
      <pose>0 0.95 1.1 0 0.15 1.5708</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.1</size></box></geometry>
        <material><ambient>0.1 0.7 0.1 1</ambient><diffuse>0.1 0.7 0.1 1</diffuse></material>
      </visual>
      <sensor name="camera_left" type="camera">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <camera>
          <horizontal_fov>1.5707963</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>20.0</far></clip>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
        </camera>
        <plugin name="camera_left_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/ego</namespace>
            <remapping>image_raw:=camera_left/image_raw</remapping>
            <remapping>camera_info:=camera_left/camera_info</remapping>
          </ros>
          <frame_name>camera_left_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="camera_left_joint" type="fixed">
      <parent>chassis</parent><child>camera_left_link</child>
    </joint>

    <!-- ============== RIGHT SIDE CAMERA (Row B / 남쪽 슬롯) ============== -->
    <!-- Mounted on the right flank (chassis -y = south when driving east).
         yaw=-π/2  → optical axis faces chassis -y (right).
         pitch=0.15 → ~9° downward tilt. -->
    <link name="camera_right_link">
      <pose>0 -0.95 1.1 0 0.15 -1.5708</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.1</size></box></geometry>
        <material><ambient>0.7 0.1 0.1 1</ambient><diffuse>0.7 0.1 0.1 1</diffuse></material>
      </visual>
      <sensor name="camera_right" type="camera">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <camera>
          <horizontal_fov>1.5707963</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>20.0</far></clip>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.007</stddev></noise>
        </camera>
        <plugin name="camera_right_plugin" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/ego</namespace>
            <remapping>image_raw:=camera_right/image_raw</remapping>
            <remapping>camera_info:=camera_right/camera_info</remapping>
          </ros>
          <frame_name>camera_right_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="camera_right_joint" type="fixed">
      <parent>chassis</parent><child>camera_right_link</child>
    </joint>

    <!-- ============== IMU ============== -->
    <link name="imu_link">
      <pose>0 0 0.5 0 0 0</pose>
      <inertial>
        <mass>0.01</mass>
        <inertia><ixx>1e-6</ixx><iyy>1e-6</iyy><izz>1e-6</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
      </inertial>
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <namespace>/ego</namespace>
            <remapping>~/out:=imu</remapping>
          </ros>
          <frame_name>imu_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent>chassis</parent><child>imu_link</child>
    </joint>

    <!-- ============== DIFF DRIVE (뒷바퀴 구동) ============== -->
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/ego</namespace></ros>

      <left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_rr_joint</right_joint>

      <wheel_separation>1.7</wheel_separation>
      <wheel_diameter>0.6</wheel_diameter>

      <max_wheel_torque>200</max_wheel_torque>
      <max_wheel_acceleration>3.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>chassis</robot_base_frame>
    </plugin>
  </model>
</sdf>
